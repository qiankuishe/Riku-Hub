{
  "name": "qiankui-sub-cf",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev:worker": "wrangler dev --config wrangler.toml",
    "dev:web": "corepack pnpm --filter @qiankui-sub-cf/web dev",
    "build": "corepack pnpm -r run build",
    "build:web": "corepack pnpm --filter @qiankui-sub-cf/web build",
    "check": "corepack pnpm -r run check",
    "test": "corepack pnpm -r run test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250312.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7",
    "wrangler": "^4.4.0"
  }
}
